{
  "name": "signalk-symbol-manager",
  "version": "0.1.0",
  "description": "Signal K server plugin and WebApp that manages a user-defined library of SVG symbols and exposes them as a read-only `symbols` resource provider for symbol-aware apps such as Freeboard-SK.",
  "main": "plugin/index.js",
  "scripts": {
    "dev": "vite",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "build": "npm run build:server && npm run build:web",
    "watch:server": "tsc -p tsconfig.json -w",
    "watch:web": "vite build --watch",
    "clean": "rm -rf plugin public/index.html public/assets",
    "test": "npm run build:server && node --test test/*.test.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-utility",
    "signalk",
    "symbols",
    "icons",
    "svg",
    "resource-provider",
    "freeboard"
  ],
  "signalk": {
    "displayName": "Symbol Manager"
  },
  "files": [
    "plugin",
    "public",
    "templates",
    "README.md",
    "REQUIREMENTS.md",
    "AGENTS.md",
    "CLAUDE.md",
    "LICENSE"
  ],
  "author": "Joel Kozikowski",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joelkoz/signalk-symbol-manager.git"
  },
  "bugs": {
    "url": "https://github.com/joelkoz/signalk-symbol-manager/issues"
  },
  "homepage": "https://github.com/joelkoz/signalk-symbol-manager#readme",
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.6"
  },
  "devDependencies": {
    "@signalk/server-api": "^2.10.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "fabric": "^6.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-tag-input-component": "^2.0.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
